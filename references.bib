@article{hubner2022,
  title = {To {{Those Who Have}}, {{More Will Be Given}}? {{Effects}} of an {{Instructional Time Reform}} on {{Gender Disparities}} in {{STEM Subjects}}, {{Stress}}, and {{Health}}},
  shorttitle = {To {{Those Who Have}}, {{More Will Be Given}}?},
  author = {H{\"u}bner, Nicolas and Wagner, Wolfgang and Meyer, Jennifer and Watt, Helen M. G.},
  year = {2022},
  month = feb,
  journal = {Frontiers in Psychology},
  volume = {13},
  publisher = {Frontiers},
  issn = {1664-1078},
  doi = {10.3389/fpsyg.2022.816358},
  urldate = {2024-11-04},
  abstract = {{$<$}p{$>$}Educational reformers all around the globe are continuously searching for ways to make schools more effective and efficient. In Germany, this movement has led to reforms that reduced overall school time of high track secondary schools from 9 to 8 years, which was compensated for by increasing average instruction time per week in lower secondary school (Grades 5--10). Based on prior research, we assumed that this reform might increase gender disparities in STEM-related outcomes, stress, and health because it required students to learn similar content in less amount of time. Therefore, we investigated how the school time reform affected gender disparities at the end of upper secondary school between 2011 and 2013. Specifically, we considered representative data of the last two cohorts who completed lower secondary school before the reform ({$<$}italic{$>$}N{$<$}/italic{$>$} = 2,405) and the first two cohorts after the reform ({$<$}italic{$>$}N{$<$}/italic{$>$} = 2,413) from the National Educational Panel Study. Potential differences in gender disparities were investigated for upper secondary school outcomes of subject-specific standardized test performance, self-concept, and interest in mathematics, biology and physics, as well as outcomes of school-related stress and health. Overall, we found substantial disparities between girls and boys, which seemed to change little after the reform. Exceptions were the statistically significant gender {\texttimes} reform interactions for one stress dimension (Overload) and two health dimensions (Overburdening and Achievement-related fear) which increased for both boys and girls, but more strongly for girls.{$<$}/p{$>$}},
  langid = {english},
  keywords = {Achievement,gender disparities,Health,Instructional time,Motivation,school reform,stem,stress},
  file = {/Users/kirstinschmidt/GDrive_Mac/zotero-library/AUTH/Hübner et al/hübner_et_al_2022_to_those_who_have,_more_will_be_given_-_effects_of_an_instructional_time_reform.pdf}
}

